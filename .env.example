# Backend API base URL used by shared apiClient.
# Vite exposes only VITE_* variables to browser code.
VITE_API_URL=http://localhost:3000

# NAVER Maps Dynamic Map client ID (provided as a GitHub Secret).
VITE_NAVER_MAP_CLIENT_ID=

# Kakao JavaScript app key (Kakao share SDK).
VITE_KAKAO_APP_KEY=

# OAuth client IDs for social login.
VITE_KAKAO_CLIENT_ID=
VITE_NAVER_CLIENT_ID=
VITE_GOOGLE_CLIENT_ID=
VITE_APPLE_CLIENT_ID=
